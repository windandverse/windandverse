---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReactionButton from '../../components/ReactionButton.astro';
import CommentSection from '../../components/CommentSection.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map(story => {
    const slug = story.id.replace(/\.[^/.]+$/, "");
    const related = stories.filter(s => s.id !== story.id).slice(0, 2);
    return {
      params: { slug },
      props: { story, slug, related },
    };
  });
}

const { story, slug, related } = Astro.props;
const { title, pubDate, image, alt, description, imageCredit } = story.data;
const { Content } = await render(story);
---

<BaseLayout title={title} description={description} ogImage={image?.src}>
    <main class="blog-fullscreen" id="story-container" data-story-title={title} data-story-excerpt={description}>
        <article>
            <div class="stories-meta-header">
                <div class="blog-meta-left">
                    <span class="blog-date-full">{pubDate ? new Date(pubDate).toLocaleDateString() : ''}</span>
                </div>
                <button class="story-meta-share-btn poem-icon-btn share-btn" aria-label="Share">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="18" cy="5" r="3"></circle>
                        <circle cx="6" cy="12" r="3"></circle>
                        <circle cx="18" cy="19" r="3"></circle>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                    </svg>
                </button>
            </div>

            <h1>{title}</h1>

            {image && (
                <div class="featured-image">
                    <Image src={image} alt={alt || title} width="1600" height="800" format="webp" style="width: 100%; height: auto; display: block; border-radius: 12px;" />
                    {imageCredit && <p class="image-caption" set:html={imageCredit} />}
                </div>
            )}

            <div class="blog-content-full">
                <Content />
            </div>

            <ReactionButton id={`story-${story.id}`} />
        </article>

        <CommentSection pageId={`story-${story.id}`} pageTitle={title} />

        {related.length > 0 && (
            <section class="related-section">
                <div class="related-header">
                    <h3>More to read</h3>
                    <div class="related-rule" aria-hidden="true"></div>
                </div>
                <div class="related-grid">
                    {related.map(item => (
                        <a href={`/stories/${item.id}`} class="related-card">
                            {item.data.image && (
                                <Image src={item.data.image} alt={item.data.alt || item.data.title} class="related-image" loading="lazy" />
                            )}
                            <div class="related-card-text">
                                <span class="related-card-category">Story</span>
                                <span class="related-card-title">{item.data.title}</span>
                                {item.data.description && (
                                    <p class="related-card-excerpt">{item.data.description}</p>
                                )}
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        )}
    </main>

    <a href="/stories" class="back-to-blog">&#8592; all posts</a>
</BaseLayout>