---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
    <main class="not-found-page">
        <div class="not-found-inner">
            <span class="not-found-number">404</span>
            <h1 class="not-found-heading">This page doesn't exist.</h1>
            <p class="not-found-body">
                Like a story without an ending, or a poem missing its last line —
                whatever you were looking for isn't here.
            </p>
            <a href="/" class="not-found-link">Go back home</a>
        </div>
    </main>
</BaseLayout>