---
// src/components/BaseHead.astro
interface Props {
    title: string;
    description?: string;
    ogImage?: string;
}

const {
    title,
    description = "Wind moves and leaves nothing behind. Verse stays forever. Together — a reminder that living is mortal, but life is not.",
    ogImage = "https://windandverse.com/social/og-home.png",
} = Astro.props;

const canonicalURL = Astro.url.href;
const fullTitle = title === "Home" ? "Wind & Verse" : `${title} — Wind & Verse`;
---

<meta charset="UTF-8">
<style>html { background-color: #1a1816; }</style>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>{fullTitle}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonicalURL}>

<!-- Favicon and App Icons -->
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="manifest" href="/site.webmanifest">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="Wind & Verse">
<meta property="og:title" content={fullTitle}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonicalURL}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">

<!-- Twitter/X -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={fullTitle}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400;1,600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap">

<!-- JSON-LD -->
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Wind & Verse",
    "url": "https://windandverse.com/",
    "description": "Poetry, stories, and blogs for people who don't fit.",
    "author": {
        "@type": "Person",
        "name": "Romeon"
    }
}
</script>