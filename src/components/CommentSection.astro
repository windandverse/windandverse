---
const APP_ID = "d3144132-1898-43d2-a665-6197a73f35ab";
const THEME_URL = "https://windandverse.com/cusdis-theme.css";

interface Props {
    pageId: string;
    pageTitle: string;
}
const { pageId, pageTitle } = Astro.props;
---

<section class="comment-section">
    <div class="comment-section-inner">
        <div class="comment-header">
            <h3>Comments</h3>
            <div class="comment-rule" aria-hidden="true"></div>
        </div>
        <p class="comment-note">Comments are moderated, yours will appear once approved.</p>

        <div
            class="cusdis-wrapper"
            id="cusdis_thread"
            data-host="https://cusdis.com"
            data-app-id={APP_ID}
            data-page-id={pageId}
            data-page-url={Astro.url.href}
            data-page-title={pageTitle}
            data-theme={THEME_URL}
        ></div>
    </div>
</section>

<script>
    const script = document.createElement('script');
    script.src = 'https://cusdis.com/js/cusdis.es.js';
    script.async = true;
    script.defer = true;
    document.body.appendChild(script);
</script>