---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css'; 
import backgroundImage from '../assets/home/ricardo-gomez-angel-jg4pkrwaico-unsplash.jpg'; 

const { 
    title, 
    description,
    ogImage,
    collectionType, 
    items = [] 
} = Astro.props;

const sidebarTitle = collectionType === 'POEMS' ? 'ALL POEMS' : 
                     collectionType === 'STORIES' ? 'ALL STORIES' : 'ALL BLOGS';
const routePrefix = collectionType === 'POEMS' ? 'poem' :
                     collectionType === 'STORIES' ? 'stories' : 'blog';
---

<!DOCTYPE html>
<html lang="en">

<head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
    <!-- Preload background image so it's ready before paint -->
    <link rel="preload" as="image" href={backgroundImage.src} />
    <style>
        /* Inline critical CSS — applies before external stylesheet loads */
        html { background-color: #1a1816; }
        body.site-bg {
            background-image: linear-gradient(rgba(0,0,0,0.25), rgba(0,0,0,0.25)), url('{BG_SRC}');
        }
    </style>
</head>

<body class="site-bg" id="site-body">

    <a href="#main-content" class="skip-to-content">Skip to content</a>

    <header>
        <a href="/" class="logo">
            <img src="/LG.png" alt="" class="logo-icon" aria-hidden="true" />
            <span class="logo-text">WIND AND VERSE</span>
        </a>

        <div class="quote-slideshow">
            <div class="quote-card">
                <div class="quote-container">
                    <div class="quote-slide active">"Meaning is limited, life is edited"</div>
                    <div class="quote-slide">"You are here. Then you won't be. That's not sad that's why we write."</div>
                    <div class="quote-slide">"No one lives on the stairs."</div>
                    <div class="quote-slide">"Perfection is sleight. Comfort in make up."</div>
                    <div class="quote-slide">"The page holds what the wind cannot."</div>
                </div>
            </div>
        </div>

        <nav class="desktop-nav">
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/blog">Blogs</a></li>
                <li><a href="/poem">Poems</a></li>
                <li><a href="/stories">Stories</a></li>
                <li><a href="/about">About</a></li>
            </ul>
        </nav>
        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Open menu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="7" x2="21" y2="7"></line>
                <line x1="7" y1="12" x2="21" y2="12"></line>
                <line x1="11" y1="17" x2="21" y2="17"></line>
            </svg>
        </button>
    </header>

    <div class="nav-overlay" id="navOverlay"></div>
    <aside class="mobile-nav-sidebar" id="mobileSidebar">
        <div class="mobile-nav-header">
            <span class="mobile-nav-logo">WIND AND VERSE</span>
            <button class="close-nav-btn" id="closeNavBtn" aria-label="Close menu">&times;</button>
        </div>
        <nav class="mobile-nav-links">
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/blog">Blogs</a></li>
                <li><a href="/poem">Poems</a></li>
                <li><a href="/stories">Stories</a></li>
                <li><a href="/about">About</a></li>
            </ul>
        </nav>
        <div class="mobile-nav-footer">
            <p>wind doesn't blow twice<br>but verse sings for life</p>
        </div>
    </aside>

    <div id="main-content">
        <slot />
    </div>

    {collectionType && (
        <>
            <div class="collection-btn-wrap" id="collectionBtnWrap">
                <button class="collection-btn" id="collectionBtn" aria-label={`Browse ${sidebarTitle.toLowerCase()}`} aria-haspopup="true" aria-expanded="false">
                    <span class="collection-btn-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="8" y1="6" x2="21" y2="6"></line>
                            <line x1="8" y1="12" x2="21" y2="12"></line>
                            <line x1="8" y1="18" x2="21" y2="18"></line>
                            <line x1="3" y1="6" x2="3.01" y2="6"></line>
                            <line x1="3" y1="12" x2="3.01" y2="12"></line>
                            <line x1="3" y1="18" x2="3.01" y2="18"></line>
                        </svg>
                    </span>
                    <span class="collection-btn-label">{sidebarTitle}</span>
                </button>
            </div>

            <div class="collection-sidebar" id="collectionSidebar">
                <div class="sidebar-header">
                    <div class="sidebar-logo">{sidebarTitle}</div>
                    <button class="close-sidebar" id="closeSidebar" aria-label="Close list">✕</button>
                </div>
                <div class="sidebar-list">
                    {items.map((item: any) => (
                        <a href={`/${routePrefix}/${item.id}`} class="sidebar-item">
                            {item.data.title}
                        </a>
                    ))}
                </div>
            </div>
        </>
    )}

    <footer>
        <div class="footer-inner">
            <div class="footer-brand">
                <a href="/" class="footer-logo-link">WIND AND VERSE</a>
                <p class="footer-tagline">Wind comes and goes like a whispered breath, but verse stays on conquering death.</p>
                <div class="footer-socials">
                    <a href="https://instagram.com/windandverse" target="_blank" rel="noopener noreferrer" class="footer-social-link">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
                        <span>Instagram</span>
                    </a>
                    <a href="https://facebook.com/windandverse" target="_blank" rel="noopener noreferrer" class="footer-social-link">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                        <span>Facebook</span>
                    </a>
                    <a href="https://windandverse.substack.com" target="_blank" rel="noopener noreferrer" class="footer-social-link">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
                        <span>Substack</span>
                    </a>
                    <a href="https://medium.com/@windandverse" target="_blank" rel="noopener noreferrer" class="footer-social-link">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
                        <span>Medium</span>
                    </a>
                    <a href="https://pinterest.com/windandverse" target="_blank" rel="noopener noreferrer" class="footer-social-link">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
                        <span>Pinterest</span>
                    </a>
                </div>
            </div>

            <div class="footer-nav-group">
                <h4>Wander</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/blog">Blogs</a></li>
                    <li><a href="/poem">Poems</a></li>
                    <li><a href="/stories">Stories</a></li>
                    <li><a href="/about">About</a></li>
                </ul>
            </div>

            <div class="footer-quote-block">
                <blockquote>"Living is mortal, but life is not."</blockquote>
                <span class="footer-name">- Roméon</span>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© 2026 WIND AND VERSE</p>
            <p class="footer-credit">I Saw. I wrote. I waS.</p>
            <a href="#" class="back-to-top">↑ back to top</a>
        </div>
    </footer>

    <!-- Set background image via JS after page load to avoid render blocking -->
    <script define:vars={{ bgSrc: backgroundImage.src }}>
        document.getElementById('site-body').style.backgroundImage = 
            `linear-gradient(rgba(0,0,0,0.25), rgba(0,0,0,0.25)), url(${bgSrc})`;
    </script>

    <script type="module">
        import "../scripts/main.js";
    </script>
</body>
</html>